{
  "name": "@rspackjs/plugin-html-tags",
  "version": "1.0.0",
  "description": "An Rspack plugin to inject extra scripts, links, and meta tags via HtmlRspackPlugin.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run typecheck && npm run format:check && npm run lint && npm run test",
    "pretest": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build && npm run test",
    "release": "release-it",
    "prepare": "husky"
  },
  "keywords": [
    "rspack",
    "rspack-plugin",
    "plugin",
    "html",
    "html-rspack-plugin",
    "tags",
    "inject",
    "scripts",
    "links",
    "metas",
    "assets"
  ],
  "author": "Anjey Tsibylskij (https://github.com/atldays)",
  "contributors": [
    "Jon Harris <harris.jb@gmail.com> (https://github.com/jharris4)"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atldays/rspack-plugin-html-tags.git"
  },
  "homepage": "https://github.com/atldays/rspack-plugin-html-tags#readme",
  "bugs": {
    "url": "https://github.com/atldays/rspack-plugin-html-tags/issues"
  },
  "peerDependencies": {
    "@rspack/core": "^1.0.13 || ^2"
  },
  "dependencies": {
    "glob": "^13.0.6",
    "minimatch": "^10.0.1"
  },
  "overrides": {
    "babel-plugin-istanbul": "^8.0.2",
    "encoding-sniffer": "^1.0.2",
    "esbuild": "^0.28.1",
    "glob": "^13.0.6",
    "js-yaml": "^4.2.0",
    "test-exclude": "^7.0.1",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^11.0.1",
    "@rspack/core": "^2.0.1",
    "@swc/core": "^1.7.0",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "cheerio": "^1.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.6",
    "jest": "^30.4.2",
    "prettier": "^3.4.0",
    "release-it": "^20.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.1"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  }
}
